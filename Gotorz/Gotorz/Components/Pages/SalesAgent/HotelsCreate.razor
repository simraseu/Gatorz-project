@page "/hotels/create"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Forms
@using Gotorz.Services
@using Gotorz.ViewModel
@using Gotorz.Models
@inject HotelService HotelService
@inject HotelApiService HotelApiService
@inject NavigationManager Navigation

<h3>Opret nyt hotel</h3>

<EditForm Model="hotelFormModel" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label>Navn</label>
        <InputText @bind-Value="hotelFormModel.Name" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Adresse</label>
        <InputText @bind-Value="hotelFormModel.Address" class="form-control" />
    </div>

    <div class="mb-3">
        <label>By</label>
        <InputText @bind-Value="hotelFormModel.City" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Land</label>
        <InputText @bind-Value="hotelFormModel.Country" class="form-control" />
    </div>


    <button type="submit" class="btn btn-primary">Gem hotel</button>
    <button type="button" class="btn btn-secondary" @onclick="GoBack">Tilbage</button>
</EditForm>

@code {
    private HotelFormViewModel hotelFormModel = new();

    private async Task HandleValidSubmit()
    {
        var hotel = new Hotel
            {
                Name = hotelFormModel.Name,
                Address = hotelFormModel.Address,
                City = hotelFormModel.City,
                Country = hotelFormModel.Country,
            
            };

        await HotelService.AddHotelAsync(hotel);
        Navigation.NavigateTo("/packages/create");
    }


    private void GoBack()
    {
        Navigation.NavigateTo("/packages/create");
    }
}

